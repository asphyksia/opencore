{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "dev",
  "model": "{env:MOA_MODEL}",
  "small_model": "{env:MOA_SMALL_MODEL}",
  "autoupdate": false,
  "lsp": true,
  "permission": {
    "edit": "ask",
    "bash": {
      "*": "ask",
      "rm -rf *": "deny",
      "rm -rf /": "deny",
      "sudo *": "deny",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "ls *": "allow",
      "cat *": "allow"
    }
  },
  "plugin": [],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    }
  },
  "agent": {
    "build": {
      "disable": true
    }
  }
}

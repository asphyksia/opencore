# Provider API keys — copy to .env and fill in the ones you use.
# opencore is model-agnostic; set whichever provider(s) you want.

# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=
# GEMINI_API_KEY=

# Active model (provider/model-id). Leave unset to use opencode's selector.
# OPENCORE_MODEL=anthropic/claude-sonnet-4-5
# OPENCORE_SMALL_MODEL=anthropic/claude-haiku-4-5

# Token budget (optional)
# OPENCORE_TOKEN_BUDGET=1000000
# OPENCORE_BUDGET_WARN=0.7

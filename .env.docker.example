# opencore Gateway (Docker) runtime secrets. Copy to .env (same dir as docker-compose.yml).
# This file is for the CONTAINER deployment. Never commit the real .env.

# Telegram bot token from @BotFather (required)
TELEGRAM_BOT_TOKEN=

# Model the agent uses (provider/model-id). Required.
# Examples: anthropic/claude-sonnet-4-5  |  openai/gpt-4o  |  ollama/qwen3-14b
OPENCORE_MODEL=
# Optional cheaper model for titles/summaries
OPENCORE_SMALL_MODEL=

# Provider API key(s) - set whichever your OPENCORE_MODEL needs.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=
# GEMINI_API_KEY=

# Default agent for remote use: chat (no shell) | dev (code execution) | plan
# SECURITY: keep 'chat' unless you accept remote code execution in the container.
OPENCORE_GATEWAY_DEFAULT_AGENT=chat

# Semantic search (optional). With `docker compose --profile embeddings up -d`,
# the bundled llama.cpp service serves harrier and these default to it.
# Leave unset for keyword-only (BM25). To use an external endpoint, set:
# OPENCORE_EMBED_BASE_URL=http://embeddings:8181/v1
# OPENCORE_EMBED_MODEL=harrier
